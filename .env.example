# Dashboard 环境变量
# 复制为 .env.local 用于本地开发
#
# ECS 部署时，敏感变量不要用明文 task definition env vars，
# 改用 AWS Parameter Store (SecureString) + ECS secrets 注入：
#   aws ssm put-parameter --name /dashboard/TIANGONG_JWT_SECRET --type SecureString --value "..."
#   aws ssm put-parameter --name /dashboard/TIANGONG_QUANT_ENC_KEY --type SecureString --value "..."
#   aws ssm put-parameter --name /dashboard/DASHBOARD_PASSWORD_HASH --type SecureString --value "..."
# 然后在 task definition 的 secrets 块引用 arn:aws:ssm:...:parameter/dashboard/XXX

# JWT 签名密钥 (本地可用任意随机字符串，生产必须与 screener 一致)
TIANGONG_JWT_SECRET=dev-secret-change-me

# 量化数据 AES-256-GCM 加密密钥 (base64, 32字节)
TIANGONG_QUANT_ENC_KEY=

# 初始管理员账号 (非敏感，可明文)
DASHBOARD_USER=admin

# 管理员密码 bcrypt hash (敏感，生产用 Parameter Store)
DASHBOARD_PASSWORD_HASH=

# 数据库路径 (ECS 上指向 EBS 挂载卷)
# REPORTS_DB_PATH=/data/dashboard/reports.db
# SCREENER_DB_PATH=/data/shared/screener.db
